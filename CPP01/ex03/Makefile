# Compiler and parameters
CXX = c++
CXXFLAGS = -Wall -Wextra -Werror -std=c++98

# File name
NAME = weapon

# Mandatory Sources
SOURCES = Weapon.cpp \
		  HumanA.cpp \
		  HumanB.cpp \
		  main.cpp
OBJECTS = $(SOURCES:.cpp=.o)
HEADERS = Weapon.hpp \
		  HumanA.hpp \
		  HumanB.hpp

# Rules
# Compile
all: $(NAME)

$(NAME): $(OBJECTS)
	$(CXX) $(CXXFLAGS) $(OBJECTS) -o $(NAME)

# Compile each .cpp into .o
%.o: %.cpp $(HEADERS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Clean object files
clean: 
	rm -f $(OBJECTS) 

# Full clean / Clean object files and executable
fclean: clean
	rm -f $(NAME)

# Recompile everything
re: fclean all

.PHONY: all clean fclean re 
